# Example environment variables for voting-system
# Copy to .env and set real values. Do NOT commit secrets to git.

# Environment
ENV=development            # development or production
DEBUG=True                 # development: True, production: False
ENV=production              # development or production
DEBUG=False                # development: True, production: False
# Django core
SECRET_KEY=change-me-local-secret
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (preferred: DATABASE_URL). In production set DATABASE_URL or POSTGRES_* values.
# Example: DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT (use a separate strong key in production)
JWT_SIGNING_KEY=change-me-very-secret

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_ALL_ORIGINS=False

# Optional security toggles (production overrides)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
