{
  "expo": {
    "name": "Mourivote",
    "slug": "voting-system-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Icon.jpeg",
    "userInterfaceStyle": "light",
    "scheme": "votingapp",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#E6F5EE"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "mr.gov.elections.mobile"
    },
    "android": {
      "package": "mr.gov.elections.mobile"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "99e6d649-2935-4364-9bf9-3e4aa9c69b8a"
      }
    }
  }
}
